{
  "name": "whoami-nextjs-id",
  "version": "0.1.3",
  "description": "Next.js-friendly client to extract IP (IPv4/IPv6), device info, and optional geo info from a request.",
  "keywords": [
    "nextjs",
    "ip",
    "ipv6",
    "ipv4",
    "geo",
    "user-agent"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/xretic/whoami-nextjs-id.git"
  },
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --clean",
    "prepublishOnly": "npm run build",
    "lint": "eslint .",
    "test": "node -e \"console.log('no tests buddy')\""
  },
  "dependencies": {
    "ua-parser-js": "^1.0.41"
  },
  "devDependencies": {
    "@types/ua-parser-js": "^0.7.39",
    "tsup": "^8.2.3",
    "typescript": "^5.5.4"
  }
}
